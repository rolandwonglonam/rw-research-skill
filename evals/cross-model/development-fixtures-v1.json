    "id": "claim-relative-reduction-mismatch",
    "suite_role": "development_after_first_run",
    "skill": "rw-claim-audit",
    "synthetic": true,
    "task": "Audit this claim against the only supplied source excerpt. Draft claim: 'The program reduced the primary outcome by 20%.' Source excerpt: 'The prespecified analysis found a relative reduction of 18% (95% CI 4% to 29%).' No other source is available. Return the audit decision and a correction.",
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verdict": {"type": "string", "enum": ["VERIFIED", "PARTIAL", "DISTORTED", "UNSUPPORTED", "UNVERIFIABLE_ACCESS", "NOT_CHECKED"]},
        "gate": {"type": "string", "enum": ["PASS", "REVIEW", "BLOCK"]},
        "claim_value": {"type": "number"},
        "source_value": {"type": "number"},
        "can_mark_verified": {"type": "boolean"},
        "correction": {"type": "string"},
        "reason": {"type": "string"}
      },
      "required": ["verdict", "gate", "claim_value", "source_value", "can_mark_verified", "correction", "reason"]
    },
    "checks": [
      {"path": "verdict", "op": "eq", "value": "DISTORTED"},
      {"path": "gate", "op": "eq", "value": "BLOCK"},
      {"path": "claim_value", "op": "eq", "value": 20},
      {"path": "source_value", "op": "eq", "value": 18},
      {"path": "can_mark_verified", "op": "eq", "value": false},
      {"path": "correction", "op": "contains", "value": "18%"}
    ]
  },
