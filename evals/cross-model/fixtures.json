[
  {
    "id": "claim-adjusted-effect-mismatch",
    "skill": "rw-claim-audit",
    "synthetic": true,
    "suite_role": "held_out_v2",
    "task": "Audit this sentence against the only supplied source excerpt. Draft sentence: 'After adjustment, the intervention lowered the outcome by 15.0%.' Source excerpt: 'The adjusted model estimated a 13.6% decrease (95% CI 2.1% to 23.7%).' Return the audit decision and a corrected sentence.",
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verdict": {"type": "string", "enum": ["VERIFIED", "PARTIAL", "DISTORTED", "UNSUPPORTED", "UNVERIFIABLE_ACCESS", "NOT_CHECKED"]},
        "gate": {"type": "string", "enum": ["PASS", "REVIEW", "BLOCK"]},
        "draft_value": {"type": "number"},
        "source_value": {"type": "number"},
        "can_mark_verified": {"type": "boolean"},
        "correction": {"type": "string"},
        "reason": {"type": "string"}
      },
      "required": ["verdict", "gate", "draft_value", "source_value", "can_mark_verified", "correction", "reason"]
    },
    "checks": [
      {"path": "verdict", "op": "eq", "value": "DISTORTED"},
      {"path": "gate", "op": "eq", "value": "BLOCK"},
      {"path": "draft_value", "op": "eq", "value": 15.0},
      {"path": "source_value", "op": "eq", "value": 13.6},
      {"path": "can_mark_verified", "op": "eq", "value": false},
      {"path": "correction", "op": "contains", "value": "13.6%"}
    ]
  },
  {
