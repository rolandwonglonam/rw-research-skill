  {
    "id": "revision-three-block-hash-drift",
    "skill": "rw-revision-patch",
    "synthetic": true,
    "suite_role": "held_out_v2",
    "task": "A patch may be applied only if all stored block hashes still match. Current blocks are R-1='Opening stays.', R-2='Current estimate is 15.0%.', and R-3='Closing stays.'. Stored hashes are R-1=h11, R-2=h22, R-3=h33. Current hashes are R-1=h11, R-2=drifted-h22, R-3=h33. The proposed replacement changes R-2 to 'Current estimate is 13.6%.'. Return the decision and all resulting blocks without inventing a hash.",
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {"type": "string", "enum": ["APPLY", "STOP"]},
        "reason_code": {"type": "string", "enum": ["OK", "HASH_MISMATCH", "SCOPE_ERROR"]},
        "modified_ids": {"type": "array", "items": {"type": "string"}},
        "blocks": {
          "type": "object",
          "additionalProperties": false,
          "properties": {"R-1": {"type": "string"}, "R-2": {"type": "string"}, "R-3": {"type": "string"}},
          "required": ["R-1", "R-2", "R-3"]
        },
        "next_step": {"type": "string"}
      },
      "required": ["status", "reason_code", "modified_ids", "blocks", "next_step"]
    },
    "checks": [
      {"path": "status", "op": "eq", "value": "STOP"},
      {"path": "reason_code", "op": "eq", "value": "HASH_MISMATCH"},
      {"path": "modified_ids", "op": "set_eq", "value": []},
      {"path": "blocks", "op": "eq", "value": {"R-1": "Opening stays.", "R-2": "Current estimate is 15.0%.", "R-3": "Closing stays."}}
    ]
  },
